$if Bash
    
    "\e[17~": "startx\C-m"
    "\e[18~": ""	
###    "\e[19~": "mc -c\C-m"	
    "\e[20~": ""
    "\e[21~": "exit\C-m"	
    "\e[22~": "ejectcd\C-m"
    "\e[23~": "cdin\C-m"



    $if TERM=linux
