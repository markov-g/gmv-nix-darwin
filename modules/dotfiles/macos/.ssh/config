# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config


Host r1pp3r-minidevbox
  HostName minidevbox.local
  User r1pp3r
  IdentityFile ~/.ssh/minidevbox

Host devel-minidevbox
  HostName minidevbox.local
  User devel
  IdentityFile ~/.ssh/minidevbox

Host r1pp3r-minidevbox-cloudflared
  HostName ssh.r1pp3r.com
  User r1pp3r
  ProxyCommand /Users/r1pp3r/PACKAGEMGMT/Homebrew/bin/cloudflared access ssh --hostname %h
  IdentityFile ~/.ssh/minidevbox

Host devel-minidevbox-cloudflared
  HostName ssh.r1pp3r.com
  User devel
  ProxyCommand /Users/r1pp3r/PACKAGEMGMT/Homebrew/bin/cloudflared access ssh --hostname %h
  IdentityFile ~/.ssh/minidevbox

Host UTM-Debian13.local-via-devel-minidevbox
  HostName 10.0.0.202
  Port 22
  ForwardX11 no
  Compression yes
  ProxyJump devel-minidevbox
  IdentityFile "/Users/r1pp3r/.ssh/id_rsa"
  User devel

Host UTM-Debian13.local-via-devel-minidevbox-cloudflared
  HostName 10.0.0.202
  Port 22
  ForwardX11 no
  Compression yes
  ProxyJump devel-minidevbox-cloudflared
  IdentityFile "/Users/r1pp3r/.ssh/id_rsa"
  User devel

Host GMvAzureDevBox
  HostName 172.31.2.4
  ForwardX11 no
  Compression yes
  IdentityFile "/Users/r1pp3r/.ssh/id_rsa"
  User azureuser

Host CSDevOpsBox
  HostName 172.31.2.4
  ForwardX11 no
